DATABASE_URL=postgresql://ddc_user:ddc_pass@db:5432/ddc_db
SECRET_KEY=clave_secreta_jwt_cambiar_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
INACTIVITY_TIMEOUT_MINUTES=30
VITE_API_URL=http://localhost:8000

# IA/OCR asistida
# Implementado hoy:
# - mock: no usa API keys; simula/estructura extracción y siempre funciona para demo.
# - local: OCR local con PyMuPDF/pdfplumber para PDF y Tesseract para imágenes.
# También se puede conectar:
# - Groq para LLM/resúmenes JSON y visión sobre imágenes.
# - Google Gemini para LLM/visión y embeddings.
# - Ollama local para LLM/embeddings usando modelos como gemma3:4b.
AI_MODE=mock
OCR_PROVIDER=mock
LLM_PROVIDER=none
EMBEDDINGS_PROVIDER=mock
AI_STRICT_MODE=true
AI_MIN_CONFIDENCE=0.82
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash
GOOGLE_EMBEDDING_MODEL=text-embedding-004
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
